{
  "name": "@rotpitch/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "dev:worker": "tsx watch --env-file=../../.env src/worker.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/index.js",
    "start:worker": "node --env-file=../../.env dist/worker.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rotpitch/shared": "workspace:*",
    "@supabase/supabase-js": "^2.45.4",
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ioredis": "^5.11.1",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
