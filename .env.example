# =============================================================================
# RotPitch — environment variables
# Copy to .env (and apps/web/.env.local, apps/api/.env) and fill in real values.
# NEVER commit real secrets. Service-role keys live ONLY in apps/api.
# =============================================================================

# ---- Supabase (shared project) ----------------------------------------------
# Public — safe to expose to the browser (apps/web).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — apps/api ONLY. Bypasses RLS. Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by the type-gen script in packages/db.
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres

# ---- Web -> API -------------------------------------------------------------
# Base URL of the Express service (EC2 public DNS / domain in prod, localhost in dev).
NEXT_PUBLIC_API_URL=http://localhost:4000
# Allowed browser origin for API CORS (the Vercel/web origin).
WEB_ORIGIN=http://localhost:3000

# ---- API service ------------------------------------------------------------
API_PORT=4000

# ---- Redis / BullMQ ---------------------------------------------------------
# In prod the EC2 docker-compose stack runs Redis as a service; compose
# overrides this to redis://redis:6379. Locally use a local Redis.
REDIS_URL=redis://127.0.0.1:6379

# ---- AWS S3 (finished video output — PRIVATE bucket, presigned GET) ---------
# Used by BOTH apps/api (upload + presign + delete) and apps/web (presign on
# read). On EC2, prefer an IAM instance role and leave the keys blank — the SDK
# reads the role automatically. On Vercel, the web needs explicit keys scoped to
# s3:GetObject on the outputs bucket. Locally, set keys for renders to complete.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_OUTPUT_BUCKET=rotpitch-outputs
# Presigned output URL lifetime (seconds); re-signed on each dashboard render.
S3_PRESIGN_EXPIRES_SEC=3600

# ---- OpenAI (Whisper transcription — hosted API) ----------------------------
# Powers auto-captions. Without it, caption renders fail (and refund); plain
# renders are unaffected.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ---- FFmpeg (override binary paths; defaults use PATH) -----------------------
# Captions need an ffmpeg built with libass/freetype. Point these at a
# libass-enabled build if the system ffmpeg lacks it.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ---- Render resource limits (OOM hardening) ---------------------------------
# Peak worker memory scales with these. Defaults are tuned for a small EC2
# instance; raise only after sizing the worker's RAM.
# Concurrent renders per worker (each is a full 1080x1920 encode):
RENDER_CONCURRENCY=1
# x264/ffmpeg thread cap (uncapped, a container x264 OOMs at encode start):
FFMPEG_THREADS=2
# x264 lookahead window in frames (bounds the lookahead buffer pool):
FFMPEG_RC_LOOKAHEAD=10
# Hard cap on a single render (ms); a hung encode is killed + the job fails/refunds:
RENDER_TIMEOUT_MS=180000

# ---- ElevenLabs (AI voiceover) ----------------------------------------------
ELEVENLABS_API_KEY=

# ---- Dodo Payments (billing — Merchant of Record, global USD + India INR) ----
# API key from the Dodo dashboard. Use a test_mode key in dev.
DODO_PAYMENTS_API_KEY=
# 'test_mode' (dev) or 'live_mode' (prod). Defaults to live_mode if unset.
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Standard-Webhooks signing secret for POST /api/webhooks/dodo:
DODO_PAYMENTS_WEBHOOK_KEY=
# One Dodo subscription product id (pdt_…) per paid plan:
DODO_PRODUCT_BASIC=
DODO_PRODUCT_POPULAR=
DODO_PRODUCT_PRO=
